{
  "name": "milu",
  "version": "0.4.12",
  "private": true,
  "description": "A Typora-like markdown editor for macOS",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build",
    "package:mac": "npm run build && electron-builder --mac --arm64 --x64",
    "package:mac:arm": "npm run build && electron-builder --mac --arm64",
    "package:mac:intel": "npm run build && electron-builder --mac --x64",
    "preview": "vite preview",
    "rename:dev-electron": "bash scripts/rename-dev-electron.sh",
    "postinstall": "electron-rebuild"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.0",
    "@excalidraw/excalidraw": "^0.18.1",
    "@milkdown/crepe": "^7.20.0",
    "@replit/codemirror-emacs": "^6.1.0",
    "@replit/codemirror-vim": "^6.3.0",
    "@types/diff": "^7.0.2",
    "@types/dompurify": "^3.0.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@zed-industries/claude-code-acp": "^0.16.2",
    "better-sqlite3": "^12.9.0",
    "diff": "^9.0.0",
    "dompurify": "^3.4.2",
    "framer-motion": "^12.38.0",
    "fzf": "^0.5.2",
    "marked": "^18.0.2",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "simple-git": "^3.36.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.milu.app",
    "productName": "Milu",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!**/*.map"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**/*",
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/bindings/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "artifactName": "${productName}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "extendInfo": {
        "NSCameraUsageDescription": "Not used.",
        "NSMicrophoneUsageDescription": "Not used."
      }
    },
    "dmg": {
      "title": "Milu ${version}",
      "icon": "build/icon.png",
      "iconSize": 96,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 180,
          "type": "file"
        },
        {
          "x": 400,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
